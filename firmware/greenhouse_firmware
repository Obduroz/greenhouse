void controlVentilation() {
  unsigned long currentTime = millis();
  
  // Проверяем защиту от частых переключений
  if (currentTime - lastVentToggle < TOGGLE_DELAY) {
    return;
  }
  
  // Если температура выше порога И форточка закрыта
  if (temperature > TEMP_HIGH && !isVentOpen) {
    Serial.println(" Открываю форточку и включаю вентилятор");
    ventServo.write(90); // Открыть форточку
    digitalWrite(FAN_PIN, HIGH);
    isVentOpen = true;
    isFanOn = true;
    lastVentToggle = currentTime;
  }
  // Если температура нормализовалась И форточка открыта
  else if (temperature <= (TEMP_HIGH - TEMP_HYSTERESIS) && isVentOpen) {
    Serial.println(" Температура нормализовалась, закрываю проветривание");
    ventServo.write(0); // Закрыть форточку
    digitalWrite(FAN_PIN, LOW);
    isVentOpen = false;
    isFanOn = false;
    lastVentToggle = currentTime;
  }
}

void controlWatering() {
  unsigned long currentTime = millis();
  
  // Проверяем защиту от частых переключений
  if (currentTime - lastPumpToggle < TOGGLE_DELAY) {
    return;
  }
  
  // Если почва сухая И помпа выключена
  if (soilMoisture > SOIL_DRY && !isPumpOn) {
    Serial.println(" Почва сухая - включаю полив");
    digitalWrite(PUMP_PIN, HIGH);
    isPumpOn = true;
    lastPumpToggle = currentTime;
  }
  // Если почва достаточно влажная И помпа включена
  else if (soilMoisture <= SOIL_WET && isPumpOn) {
    Serial.println(" Почва достаточно влажная - выключаю полив");
    digitalWrite(PUMP_PIN, LOW);
    isPumpOn = false;
    lastPumpToggle = currentTime;
  }
  
  // Защита от бесконечного полива
  if (isPumpOn && (currentTime - lastPumpToggle > 300000)) { // 5 минут
    Serial.println(" Аварийное отключение помпы (превышено время работы)");
    digitalWrite(PUMP_PIN, LOW);
    isPumpOn = false;
    lastPumpToggle = currentTime;
  }
}

void controlHeating() {
  unsigned long currentTime = millis();
  
  // Проверяем защиту от частых переключений
  if (currentTime - lastHeaterToggle < TOGGLE_DELAY) {
    return;
  }
  
  // Если температура ниже порога И подогрев выключен
  if (temperature < TEMP_LOW && !isHeaterOn) {
    Serial.println(" Температура ниже " + String(TEMP_LOW) + "°C");
    Serial.println(" Включаю подогрев");
    digitalWrite(HEATER_PIN, HIGH);
    isHeaterOn = true;
    lastHeaterToggle = currentTime;
  }
  // Если температура поднялась выше порога+гистерезис И подогрев включен
  else if (temperature > (TEMP_LOW + TEMP_HYSTERESIS) && isHeaterOn) {
    Serial.println(" Температура нормализовалась, выключаю подогрев");
    digitalWrite(HEATER_PIN, LOW);
    isHeaterOn = false;
    lastHeaterToggle = currentTime;
  }
}

void controlLighting() {
  unsigned long currentTime = millis();
  
  // Проверяем защиту от частых переключений
  if (currentTime - lastLightToggle < TOGGLE_DELAY) {
    return;
  }
  
  // Если темно И подсветка выключена
  if (lightLevel > LIGHT_LOW && !isLightOn) {
    Serial.println(" Темно - включаю подсветку");
    digitalWrite(LIGHT_RELAY_PIN, HIGH);
    isLightOn = true;
    lastLightToggle = currentTime;
  }
  // Если стало светло И подсветка включена
  else if (lightLevel <= LIGHT_HIGH && isLightOn) {
    Serial.println(" Стало светло - выключаю подсветку");
    digitalWrite(LIGHT_RELAY_PIN, LOW);
    isLightOn = false;
    lastLightToggle = currentTime;
  }
}

void sendDataToServer() {
  // Проверяем интервал отправки
  if (millis() - lastSendTime < SEND_INTERVAL && lastSendTime != 0) {
    return;
  }
  
  // Проверяем подключение к WiFi
  if (WiFi.status() != WL_CONNECTED) {
    Serial.println("❌ WiFi не подключен. Переподключение...");
    connectToWiFi();
    return;
  }
  
  // Создаем JSON объект с данными датчиков и состояниями устройств
  DynamicJsonDocument doc(1024);
  
  doc["temperature"] = temperature;
  doc["humidity"] = humidity;
  doc["soil_moisture"] = soilMoisture;
  doc["light_level"] = lightLevel;
  doc["timestamp"] = millis() / 1000;
  
  // Добавляем состояния устройств
  doc["devices"]["vent"] = isVentOpen;
  doc["devices"]["fan"] = isFanOn;
  doc["devices"]["heater"] = isHeaterOn;
  doc["devices"]["light"] = isLightOn;
  doc["devices"]["pump"] = isPumpOn;
  
  // Конвертируем в строку
  String jsonString;
  serializeJson(doc, jsonString);
  
  Serial.println(" Отправка данных на сервер...");
  Serial.println(jsonString);
  
  WiFiClientSecure client;
  client.setInsecure(); // Отключаем проверку сертификата (для простоты)
  
  HTTPClient http;
  http.begin(client, serverURL);
  http.addHeader("Content-Type", "application/json");
  
  int httpCode = http.POST(jsonString);
  
  if (httpCode > 0) {
    Serial.printf(" Данные отправлены. Код ответа: %d\n", httpCode);
  } else {
    Serial.printf(" Ошибка отправки: %s\n", http.errorToString(httpCode).c_str());
  }
  
  http.end();
  lastSendTime = millis();
}
