// ПИНЫ ДЛЯ ДАТЧИКОВ
#define LIGHT_PIN 34     // Фоторезистор
#define DHT_PIN 4        // DHT11
#define SOIL_PIN 35      // Датчик влажности почвы
#define SERVO_PIN 5      // Сервопривод форточки
#define FAN_PIN 19      // Вентилятор был 13, походу 13 ломаный
#define PUMP_PIN 26       // Помпа (реле)
#define HEATER_PIN 27    // Подогрев (реле)
#define LIGHT_RELAY_PIN 18 // Подсветка (реле)

// ПОРОГИ
#define TEMP_HIGH 25     // Температура для проветривания
#define TEMP_LOW 22      // Порог для включения подогрева
#define SOIL_DRY 1500    // Порог сухой почвы 
#define SOIL_WET 800     // Порог влажной почвы 
#define LIGHT_LOW 1000   // Порог низкой освещенности
#define LIGHT_HIGH 800   // Порог достаточной освещенности

// Гистерезис для температуры
#define TEMP_HYSTERESIS 0.2

// Библиотеки
#include <soc/rtc_cntl_reg.h>
#include <DHT.h>
#include <ESP32Servo.h>
#include <WiFi.h>
#include <HTTPClient.h>
#include <ArduinoJson.h>
#include <WiFiClientSecure.h>

DHT dht(DHT_PIN, DHT11);
Servo ventServo;

// Переменные для датчиков
int soilMoisture = 0;
float temperature = 0;
float humidity = 0;
int lightLevel = 0;

// Переменные состояния
bool isVentOpen = false;
bool isHeaterOn = false;
bool isLightOn = false;
bool isFanOn = false;
bool isPumpOn = false;

// Таймеры для защиты от частых переключений
unsigned long lastVentToggle = 0;
unsigned long lastHeaterToggle = 0;
unsigned long lastLightToggle = 0;
unsigned long lastPumpToggle = 0;
const unsigned long TOGGLE_DELAY = 3000;

// Переменные для WiFi
const char* ssid = "Abc";
const char* password = "12345678";
const char* serverURL = "https://bbaukkmlitktnpqqhulp.containers.yandexcloud.net/api/data";
unsigned long lastSendTime = 0;
const unsigned long SEND_INTERVAL = 10000; // Отправлять каждые 10 секунд

void setup() {
  WRITE_PERI_REG(RTC_CNTL_BROWN_OUT_REG, 0);
  setCpuFrequencyMhz(80);
  
  Serial.begin(115200);
  delay(2000);
  
  Serial.println("=== СИСТЕМА УПРАВЛЕНИЯ ТЕПЛИЦЕЙ ===");

  // Выключить все в начальном состоянии
  pinMode(FAN_PIN, OUTPUT);
  pinMode(PUMP_PIN, OUTPUT);
  pinMode(HEATER_PIN, OUTPUT);
  pinMode(LIGHT_RELAY_PIN, OUTPUT);
  
  digitalWrite(FAN_PIN, LOW);
  digitalWrite(PUMP_PIN, LOW);
  digitalWrite(HEATER_PIN, LOW);
  digitalWrite(LIGHT_RELAY_PIN, LOW);
  
  ventServo.attach(SERVO_PIN);
  ventServo.write(0); // Форточка закрыта
  
  // Подключаемся к WiFi
  connectToWiFi();

  // Инициализация датчиков
  dht.begin();
  pinMode(SOIL_PIN, INPUT);
  pinMode(LIGHT_PIN, INPUT);
  
  Serial.println("Система готова к работе");
  Serial.println("=============================");
}

void connectToWiFi() {
  Serial.print("Подключение к WiFi ");
  Serial.println(ssid);
  
  WiFi.begin(ssid, password);
  
  int attempts = 0;
  while (WiFi.status() != WL_CONNECTED && attempts < 20) {
    delay(2000);
    Serial.print(".");
    attempts++;
  }
  
  if (WiFi.status() == WL_CONNECTED) {
    Serial.println("\n WiFi подключен!");
    Serial.print("IP адрес: ");
    Serial.println(WiFi.localIP());
  } else {
    Serial.println("\n Ошибка подключения к WiFi!");
  }
}

void loop() {
  // Чтение данных с датчиков
  readSensors();
  
  // Вывод в монитор порта
  printSensorData();
  
  // Управление проветриванием
  controlVentilation();
  
  // Управление поливом (помпа)
  controlWatering();
  
  // Управление подогревом
  controlHeating();
  
  // Управление подсветкой
  controlLighting();

  // Отправка данных на сервер
  sendDataToServer();
  
  // Задержка между циклами
  delay(2000);
}

void readSensors() {
  // Датчик температуры и влажности воздуха
  temperature = dht.readTemperature();
  humidity = dht.readHumidity();
  
  if (isnan(temperature) || isnan(humidity)) {
    Serial.println("Ошибка чтения DHT!");
    temperature = -99;
    humidity = -99;
  }
  
  // Датчик влажности почвы
  soilMoisture = analogRead(SOIL_PIN);
  
  // Датчик освещенности
  lightLevel = analogRead(LIGHT_PIN);
}

